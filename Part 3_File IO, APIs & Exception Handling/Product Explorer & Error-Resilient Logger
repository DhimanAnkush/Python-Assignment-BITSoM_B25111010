    "import requests\n",
    "from datetime import datetime\n",
    "\n",
    "# --- Logging Helper Function ---\n",
    "def log_error(function_name, error_type, message):\n",
    "    \"\"\"Writes a timestamped error message to error_log.txt\"\"\"\n",
    "    timestamp = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n",
    "    log_entry = f\"[{timestamp}] ERROR in {function_name}: {error_type} — {message}\\n\"\n",
    "    \n",
    "    try:\n",
    "        # Append mode 'a' ensures we don't overwrite previous logs\n",
    "        with open(\"error_log.txt\", \"a\", encoding=\"utf-8\") as f:\n",
    "            f.write(log_entry)\n",
    "    except Exception as e:\n",
    "        print(f\"Failed to write to log file: {e}\")\n",
    "\n",
    "# --- Triggering Errors for Testing ---\n",
    "\n",
    "def trigger_test_errors():\n",
    "    print(\"--- Starting Error Logging Test ---\")\n",
    "    \n",
    "    # 1. Triggering a ConnectionError (Unreachable URL)\n",
    "    print(\"\\nAttempting to reach an invalid host...\")\n",
    "    fake_url = \"https://this-host-does-not-exist-xyz.com/api\"\n",
    "    try:\n",
    "        # Short timeout to trigger the error quickly\n",
    "        requests.get(fake_url, timeout=3)\n",
    "    except requests.exceptions.ConnectionError as ce:\n",
    "        print(\"Caught ConnectionError. Logging now...\")\n",
    "        log_error(\"fetch_products\", \"ConnectionError\", \"No connection could be made\")\n",
    "    except Exception as e:\n",
    "        log_error(\"fetch_products\", \"UnexpectedError\", str(e))\n",
    "\n",
    "    # 2. Triggering an HTTP 404 Error (Non-existent Product)\n",
    "    print(\"\\nLooking up a non-existent product ID...\")\n",
    "    invalid_id = 999\n",
    "    lookup_url = f\"https://dummyjson.com/products/{invalid_id}\"\n",
    "    \n",
    "    try:\n",
    "        response = requests.get(lookup_url)\n",
    "        if response.status_code != 200:\n",
    "            print(f\"Caught HTTP {response.status_code}. Logging now...\")\n",
    "            error_msg = f\"{response.status_code} Not Found for product ID {invalid_id}\"\n",
    "            log_error(\"lookup_product\", \"HTTPError\", error_msg)\n",
    "        else:\n",
    "            print(\"Product unexpectedly found!\")\n",
    "    except Exception as e:\n",
    "        log_error(\"lookup_product\", \"InternalError\", str(e))\n",
