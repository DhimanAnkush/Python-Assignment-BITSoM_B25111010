    "import requests\n",
    "\n",
    "# --- Part 1: Guarded Calculator ---\n",
    "def safe_divide(a, b):\n",
    "    try:\n",
    "        return a / b\n",
    "    except ZeroDivisionError:\n",
    "        return \"Error: Cannot divide by zero\"\n",
    "    except TypeError:\n",
    "        return \"Error: Invalid input types\"\n",
    "\n",
    "print(\"--- Part A: Testing Calculator ---\")\n",
    "print(f\"10 / 2:    {safe_divide(10, 2)}\")\n",
    "print(f\"10 / 0:    {safe_divide(10, 0)}\")\n",
    "print(f\"'ten' / 2: {safe_divide('ten', 2)}\")\n",
    "\n",
    "\n",
    "# --- Part 2: Guarded File Reader ---\n",
    "def read_file_safe(filename):\n",
    "    print(f\"\\nAttempting to read: {filename}\")\n",
    "    try:\n",
    "        with open(filename, 'r', encoding=\"utf-8\") as f:\n",
    "            content = f.read()\n",
    "            return content\n",
    "    except FileNotFoundError:\n",
    "        return f\"Error: File '{filename}' not found.\"\n",
    "    finally:\n",
    "        # This runs no matter what happened above\n",
    "        print(\"File operation attempt complete.\")\n",
    "\n",
    "print(\"\\n--- Part B: Testing File Reader ---\")\n",
    "# Testing with existing file from Task 1\n",
    "print(read_file_safe(\"python_notes.txt\"))\n",
    "# Testing with non-existent file\n",
    "print(read_file_safe(\"ghost_file.txt\"))\n",
    "\n",
    "\n",
    "# --- Part 3 & 4: Robust API Calls & Validation Loop ---\n",
    "def product_lookup_system():\n",
    "    print(\"\\n--- Part C & D: Robust Product Lookup ---\")\n",
    "    base_url = \"https://dummyjson.com/products\"\n",
    "\n",
    "    while True:\n",
    "        user_input = input(\"\\nEnter a product ID to look up (1-100), or 'quit' to exit: \").strip().lower()\n",
    "        \n",
    "        if user_input == 'quit':\n",
    "            print(\"Exiting lookup system...\")\n",
    "            break\n",
    "        \n",
    "        # Validation Logic\n",
    "        if not user_input.isdigit():\n",
    "            print(\"Warning: Please enter a valid whole number.\")\n",
    "            continue\n",
    "            \n",
    "        product_id = int(user_input)\n",
    "        if not (1 <= product_id <= 100):\n",
    "            print(\"Warning: ID must be between 1 and 100.\")\n",
    "            continue\n",
    "\n",
    "        # API Call with robust error handling\n",
    "        try:\n",
    "            # Adding a 5-second timeout as requested\n",
    "            response = requests.get(f\"{base_url}/{product_id}\", timeout=5)\n",
    "            \n",
    "            # Check HTTP Status Codes manually\n",
    "            if response.status_code == 404:\n",
    "                print(f\"Product #{product_id} not found (404).\")\n",
    "            elif response.status_code == 200:\n",
    "                data = response.json()\n",
    "                print(f\"FOUND: {data['title']} - ${data['price']}\")\n",
    "            else:\n",
    "                print(f\"Server returned an unexpected status: {response.status_code}\")\n",
    "\n",
    "        except requests.exceptions.ConnectionError:\n",
