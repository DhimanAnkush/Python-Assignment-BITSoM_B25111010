    "import requests\n",
    "\n",
    "# Base configuration\n",
    "BASE_URL = \"https://dummyjson.com/products\"\n",
    "\n",
    "def run_api_tasks():\n",
    "    # --- Step 1: Fetch and Display Products ---\n",
    "    print(\"--- Step 1: Fetching 20 Products ---\")\n",
    "    try:\n",
    "        response = requests.get(f\"{BASE_URL}?limit=20\")\n",
    "        response.raise_for_status() # Check for HTTP errors\n",
    "        data = response.json()\n",
    "        products = data.get('products', [])\n",
    "\n",
    "        # Table Header\n",
    "        header = f\"{'ID':<4}| {'Title':<30} | {'Category':<15} | {'Price':<8} | Rating\"\n",
    "        print(header)\n",
    "        print(\"-\" * len(header))\n",
    "\n",
    "        for p in products:\n",
    "            p_id = p.get('id')\n",
    "            title = p.get('title')[:28] # Truncate long titles\n",
    "            cat = p.get('category')\n",
    "            price = f\"${p.get('price'):.2f}\"\n",
    "            rating = p.get('rating')\n",
    "            print(f\"{p_id:<4}| {title:<30} | {cat:<15} | {price:<8} | {rating}\")\n",
    "\n",
    "        # --- Step 2: Filter and Sort ---\n",
    "        print(\"\\n--- Step 2: High-Rated Products (>= 4.5) Sorted by Price ---\")\n",
    "        \n",
    "        # Filtering using a standard list comprehension\n",
    "        high_rated = [p for p in products if p.get('rating', 0) >= 4.5]\n",
    "        \n",
    "        # Sorting by price descending\n",
    "        # We use a lambda here because it's the standard Pythonic way to sort dicts\n",
    "        high_rated.sort(key=lambda x: x['price'], reverse=True)\n",
    "\n",
    "        for p in high_rated:\n",
    "            print(f\"Price: ${p['price']:>7.2f} | Rating: {p['rating']} | {p['title']}\")\n",
    "\n",
    "        # --- Step 3: Search by Category (Laptops) ---\n",
    "        print(\"\\n--- Step 3: Laptops Category ---\")\n",
    "        laptop_res = requests.get(f\"{BASE_URL}/category/laptops\")\n",
    "        laptops = laptop_res.json().get('products', [])\n",
    "        \n",
    "        if not laptops:\n",
    "            print(\"No laptops found.\")\n",
    "        for lp in laptops:\n",
    "            print(f\"- {lp['title']}: ${lp['price']}\")\n",
    "\n",
    "        # --- Step 4: Simulated POST Request ---\n",
    "        print(\"\\n--- Step 4: Adding Custom Product (Simulated) ---\")\n",
    "        new_product = {\n",
    "            \"title\": \"My Custom Product\",\n",
    "            \"price\": 999,\n",
    "            \"category\": \"electronics\",\n",
    "            \"description\": \"A product I created via API\"\n",
    "        }\n",
    "        \n",
    "        # Sending the POST request\n",
    "        post_res = requests.post(f\"{BASE_URL}/add\", json=new_product)\n",
    "        print(\"Server Response Status:\", post_res.status_code)\n",
    "        print(\"Response JSON:\", post_res.json())\n",
    "\n",
    "    except requests.exceptions.RequestException as e:\n",
    "        print(f\"Network error occurred: {e}\")\n",
    "    except Exception as e:\n",
    "        print(f\"An unexpected error occurred: {e}\")\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    run_api_tasks()"
   ]
