    "import copy\n",
    "\n",
    "# Provided Inventory Data\n",
    "inventory = {\n",
    "    \"Paneer Tikka\":   {\"stock\": 10, \"reorder_level\": 3},\n",
    "    \"Chicken Wings\":  {\"stock\":  8, \"reorder_level\": 2},\n",
    "    \"Veg Soup\":       {\"stock\": 15, \"reorder_level\": 5},\n",
    "    \"Butter Chicken\": {\"stock\": 12, \"reorder_level\": 4},\n",
    "    \"Dal Tadka\":      {\"stock\": 20, \"reorder_level\": 5},\n",
    "    \"Veg Biryani\":    {\"stock\":  6, \"reorder_level\": 3},\n",
    "    \"Garlic Naan\":    {\"stock\": 30, \"reorder_level\": 10},\n",
    "    \"Gulab Jamun\":    {\"stock\":  5, \"reorder_level\": 2},\n",
    "    \"Rasgulla\":       {\"stock\":  4, \"reorder_level\": 3},\n",
    "    \"Ice Cream\":      {\"stock\":  7, \"reorder_level\": 4},\n",
    "}\n",
    "\n",
    "# --- 1. Deep Copy Demonstration ---\n",
    "\n",
    "# Create a true backup that won't change if the original nested dicts change\n",
    "inventory_backup = copy.deepcopy(inventory)\n",
    "\n",
    "# Manual change to test independence\n",
    "print(\"--- Testing Deep Copy Independence ---\")\n",
    "inventory[\"Paneer Tikka\"][\"stock\"] = 999\n",
    "print(f\"Current Inventory (Modified): {inventory['Paneer Tikka']['stock']}\")\n",
    "print(f\"Backup Inventory (Original): {inventory_backup['Paneer Tikka']['stock']}\")\n",
    "\n",
    "# Restore to original state for the rest of the task\n",
    "inventory[\"Paneer Tikka\"][\"stock\"] = 10\n",
    "print(\"Inventory restored to original state.\\n\")\n",
    "\n",
    "\n",
    "# --- 2. Order Fulfillment (Using Cart from Task 2) ---\n",
    "\n",
    "# Re-creating the final cart from Task 2 for context:\n",
    "# Task 2 ended with: Paneer Tikka x3 (Gulab Jamun was removed)\n",
    "final_cart = [{\"item\": \"Paneer Tikka\", \"quantity\": 3, \"price\": 180.0}]\n",
    "\n",
    "print(\"--- Processing Order Fulfillment ---\")\n",
    "for order in final_cart:\n",
    "    item_name = order['item']\n",
    "    qty_needed = order['quantity']\n",
    "    \n",
    "    if item_name in inventory:\n",
    "        current_stock = inventory[item_name]['stock']\n",
    "        \n",
    "        if current_stock >= qty_needed:\n",
    "            inventory[item_name]['stock'] -= qty_needed\n",
    "            print(f\"Fulfilled: {qty_needed}x {item_name}\")\n",
    "        else:\n",
    "            # Insufficient stock logic\n",
    "            print(f\"⚠ Warning: Insufficient stock for {item_name}.\")\n",
    "            print(f\"Deducting available {current_stock} units only.\")\n",
    "            inventory[item_name]['stock'] = 0\n",
    "    else:\n",
    "        print(f\"Skipping: {item_name} not found in inventory.\")\n",
    "\n",
    "\n",
    "# --- 3. Reorder Alerts ---\n",
    "\n",
    "print(\"\\n--- Low Stock Alerts ---\")\n",
    "for item, details in inventory.items():\n",
    "    stock = details['stock']\n",
    "    limit = details['reorder_level']\n",
    "    \n",
    "    if stock <= limit:\n",
    "        print(f\"⚠ Reorder Alert: {item} — Only {stock} unit(s) left (reorder level: {limit})\")\n",
    "\n",
    "\n",
    "# --- 4. Final Verification ---\n",
    "\n",
    "print(\"\\n--- Final Integrity Check ---\")\n",
    "# Proving inventory was changed but backup remained at 10 for Paneer Tikka\n",
    "print(f\"Final Paneer Tikka Stock:  {inventory['Paneer Tikka']['stock']}\")\n",
    "print(f\"Backup Paneer Tikka Stock: {inventory_backup['Paneer Tikka']['stock']}\")"
   ]
