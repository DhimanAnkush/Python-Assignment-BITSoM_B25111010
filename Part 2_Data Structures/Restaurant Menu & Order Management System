    "menu = {\n",
    "    \"Paneer Tikka\":   {\"category\": \"Starters\",  \"price\": 180.0, \"available\": True},\n",
    "    \"Chicken Wings\":  {\"category\": \"Starters\",  \"price\": 220.0, \"available\": False},\n",
    "    \"Veg Soup\":       {\"category\": \"Starters\",  \"price\": 120.0, \"available\": True},\n",
    "    \"Butter Chicken\": {\"category\": \"Mains\",     \"price\": 320.0, \"available\": True},\n",
    "    \"Dal Tadka\":      {\"category\": \"Mains\",     \"price\": 180.0, \"available\": True},\n",
    "    \"Veg Biryani\":    {\"category\": \"Mains\",     \"price\": 250.0, \"available\": True},\n",
    "    \"Garlic Naan\":    {\"category\": \"Mains\",     \"price\":  40.0, \"available\": True},\n",
    "    \"Gulab Jamun\":    {\"category\": \"Desserts\",  \"price\":  90.0, \"available\": True},\n",
    "    \"Rasgulla\":       {\"category\": \"Desserts\",  \"price\":  80.0, \"available\": True},\n",
    "    \"Ice Cream\":      {\"category\": \"Desserts\",  \"price\": 110.0, \"available\": False},\n",
    "}\n",
    "\n",
    "# --- 1. Formatted Menu by Category ---\n",
    "\n",
    "# First, let's get a unique list of categories in order\n",
    "# Using a list like this preserves a logical flow (Starters -> Mains -> Desserts)\n",
    "categories = [\"Starters\", \"Mains\", \"Desserts\"]\n",
    "\n",
    "for cat in categories:\n",
    "    print(f\"\\n===== {cat} =====\")\n",
    "    \n",
    "    for item, details in menu.items():\n",
    "        if details['category'] == cat:\n",
    "            availability = \"Available\" if details['available'] else \"Unavailable\"\n",
    "            # Using :<16 for name alignment and :>7.2f for price formatting\n",
    "            print(f\"{item:<16} ₹{details['price']:>7.2f}   [{availability}]\")\n",
    "\n",
    "print(\"\\n\" + \"=\"*30)\n",
    "\n",
    "# --- 2. Menu Insights & Computations ---\n",
    "\n",
    "# Total number of items\n",
    "total_items = len(menu)\n",
    "\n",
    "# Count available items\n",
    "available_count = 0\n",
    "for details in menu.values():\n",
    "    if details['available']:\n",
    "        available_count += 1\n",
    "\n",
    "# Find the most expensive item\n",
    "# We initialize with a placeholder or the first item\n",
    "most_expensive_name = \"\"\n",
    "highest_price = 0.0\n",
    "\n",
    "for name, details in menu.items():\n",
    "    if details['price'] > highest_price:\n",
    "        highest_price = details['price']\n",
    "        most_expensive_name = name\n",
    "\n",
    "# Items under ₹150\n",
    "budget_items = []\n",
    "for name, details in menu.items():\n",
    "    if details['price'] < 150:\n",
    "        budget_items.append(f\"{name} (₹{details['price']})\")\n",
    "\n",
    "# Final Printout\n",
    "print(f\"Total Menu Items:      {total_items}\")\n",
    "print(f\"Items Available Now:   {available_count}\")\n",
    "print(f\"Most Expensive Item:   {most_expensive_name} - ₹{highest_price}\")\n",
    "print(f\"Budget Items (<₹150):  {', '.join(budget_items)}\")"
