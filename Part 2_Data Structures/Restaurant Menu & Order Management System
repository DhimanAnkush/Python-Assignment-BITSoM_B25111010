   "source": [
    "# Initial Setup\n",
    "cart = []\n",
    "\n",
    "# Provided Menu from Task 1\n",
    "menu = {\n",
    "    \"Paneer Tikka\":   {\"category\": \"Starters\",  \"price\": 180.0, \"available\": True},\n",
    "    \"Chicken Wings\":  {\"category\": \"Starters\",  \"price\": 220.0, \"available\": False},\n",
    "    \"Veg Soup\":       {\"category\": \"Starters\",  \"price\": 120.0, \"available\": True},\n",
    "    \"Butter Chicken\": {\"category\": \"Mains\",     \"price\": 320.0, \"available\": True},\n",
    "    \"Dal Tadka\":      {\"category\": \"Mains\",     \"price\": 180.0, \"available\": True},\n",
    "    \"Veg Biryani\":    {\"category\": \"Mains\",     \"price\": 250.0, \"available\": True},\n",
    "    \"Garlic Naan\":    {\"category\": \"Mains\",     \"price\":  40.0, \"available\": True},\n",
    "    \"Gulab Jamun\":    {\"category\": \"Desserts\",  \"price\":  90.0, \"available\": True},\n",
    "    \"Rasgulla\":       {\"category\": \"Desserts\",  \"price\":  80.0, \"available\": True},\n",
    "    \"Ice Cream\":      {\"category\": \"Desserts\",  \"price\": 110.0, \"available\": False},\n",
    "}\n",
    "\n",
    "# --- Helper Functions for Logic ---\n",
    "\n",
    "def add_to_cart(item_name, qty):\n",
    "    # 1. Check if item exists in menu\n",
    "    if item_name not in menu:\n",
    "        print(f\"Error: '{item_name}' is not on our menu.\")\n",
    "        return\n",
    "\n",
    "    # 2. Check if item is available\n",
    "    if not menu[item_name]['available']:\n",
    "        print(f\"Sorry: '{item_name}' is currently unavailable.\")\n",
    "        return\n",
    "\n",
    "    # 3. Check if already in cart to update quantity\n",
    "    found = False\n",
    "    for entry in cart:\n",
    "        if entry['item'] == item_name:\n",
    "            entry['quantity'] += qty\n",
    "            found = True\n",
    "            break\n",
    "    \n",
    "    # 4. If not found, add new entry\n",
    "    if not found:\n",
    "        cart.append({\n",
    "            \"item\": item_name, \n",
    "            \"quantity\": qty, \n",
    "            \"price\": menu[item_name]['price']\n",
    "        })\n",
    "    print(f\"Added {qty}x {item_name} to cart.\")\n",
    "\n",
    "def remove_from_cart(item_name):\n",
    "    for i in range(len(cart)):\n",
    "        if cart[i]['item'] == item_name:\n",
    "            cart.pop(i)\n",
    "            print(f\"Removed '{item_name}' from cart.\")\n",
    "            return\n",
    "    print(f\"Error: '{item_name}' not found in your cart.\")\n",
    "\n",
    "# --- Simulation Sequence ---\n",
    "\n",
    "print(\"--- Starting Order Simulation ---\")\n",
    "\n",
    "# Step 1: Add Paneer Tikka x 2\n",
    "add_to_cart(\"Paneer Tikka\", 2)\n",
    "\n",
    "# Step 2: Add Gulab Jamun x 1\n",
    "add_to_cart(\"Gulab Jamun\", 1)\n",
    "\n",
    "# Step 3: Add Paneer Tikka x 1 (Updates to 3)\n",
    "add_to_cart(\"Paneer Tikka\", 1)\n",
    "\n",
    "# Step 4: Mystery Burger\n",
    "add_to_cart(\"Mystery Burger\", 1)\n",
    "\n",
    "# Step 5: Chicken Wings (Unavailable)\n",
    "add_to_cart(\"Chicken Wings\", 1)\n",
    "\n",
    "# Step 6: Remove Gulab Jamun\n",
    "remove_from_cart(\"Gulab Jamun\")\n",
    "\n",
    "# --- Final Order Summary ---\n",
    "\n",
    "print(\"\\n========== Order Summary ==========\")\n",
    "subtotal = 0.0\n",
    "\n",
    "for entry in cart:\n",
    "    item_total = entry['price'] * entry['quantity']\n",
    "    subtotal += item_total\n",
    "    # Formatting: Name(left-aligned), Quantity, Item Total(right-aligned)\n",
    "    print(f\"{entry['item']:18} x{entry['quantity']}    ₹{item_total:>7.2f}\")\n",
    "\n",
    "gst = subtotal * 0.05\n",
    "total_payable = subtotal + gst\n",
    "\n",
    "print(\"-\" * 35)\n",
    "print(f\"{'Subtotal:':18}      ₹{subtotal:>7.2f}\")\n",
    "print(f\"{'GST (5%):':18}      ₹{gst:>7.2f}\")\n",
    "print(f\"{'Total Payable:':18}      ₹{total_payable:>7.2f}\")\n",
    "print(\"====================================\")"
   ]
